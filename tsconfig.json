{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@eigenpal/docx-core": ["./packages/core/src/core.ts"],
      "@eigenpal/docx-core/*": ["./packages/core/src/*"],
      "@eigenpal/docx-editor-vue": ["./packages/vue/src/index.ts"],
      "@eigenpal/docx-editor-vue/*": ["./packages/vue/src/*"]
    }
  },
  "include": ["src", "packages/core/src", "packages/vue/src"],
  "exclude": ["node_modules", "dist"],
  "vueCompilerOptions": {}
}
